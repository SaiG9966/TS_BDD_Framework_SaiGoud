# Execution
BROWSER=chromium
HEADLESS=false
MAXIMIZE_BROWSER=true
SLOW_MO=300
DEFAULT_TIMEOUT_MS=60000
ACTION_TIMEOUT_MS=10000
NAVIGATION_TIMEOUT_MS=30000
PARALLEL=0
RETRY=0
TAGS=@basicControls

# URLs
BASIC_CONTROLS_URL=https://www.hyrtutorials.com/p/basic-controls.html
MULTIPLE_WINDOWS_URL=https://www.hyrtutorials.com/p/window-handles-practice.html
BASE_URL=https://www.google.com
NOP_COMMERCE_URL=https://demo.nopcommerce.com/
LOGIN_URL=https://demo.nopcommerce.com/login
FEATURE_PATH=
PRACTICE_FORM_URL=https://demoqa.com/automation-practice-form


# Credentials
APP_USERNAME=
APP_PASSWORD=
ALLOW_MANUAL_VERIFICATION=true
MANUAL_VERIFICATION_TIMEOUT_MS=120000

# Reporting
ALLURE_RESULTS_DIR=allure-results
SCREENSHOT_ON_FAILURE=true
ATTACH_SCREENSHOTS=true
RECORD_VIDEO=true
TRACE=false
HIGHLIGHT_ELEMENTS=true
